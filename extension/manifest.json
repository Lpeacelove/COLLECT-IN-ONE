{
  "manifest_version": 3,
  "name": "Collect In One",
  "version": "1.0.0",
  "description": "收藏当前页面到 Collect In One",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "收藏此页面"
  },
  "options_page": "options.html"
}
